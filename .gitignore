# Datasets are fetched, never committed (see datasets/README.md)
datasets/*
!datasets/README.md

# Build and run artifacts
target/
node_modules/
__pycache__/
.venv/
*.log

# Souffle and SQLite are vendored C/C++ source trees, fetched and built
# by their pinned scripts, never committed — only the scripts (and the
# hashes inside them) are. This must name each vendored opponent
# explicitly: opponents/*/src/ would also blackhole opponents that are
# our own Rust crates (e.g. tantivy-runner), whose src/ is real source.
opponents/souffle/src/
opponents/sqlite/src/
opponents/*/dist/
opponents/*/*.tar.gz

# SHA-256 receipts of fetched datasets are runtime artifacts; the pins
# live in the fetch scripts.
*.sha256
